{%- comment -%}
  AVELO — Success Stories / Testimonial Wall
  Card grid: customer photo, star rating, quote, name, verified badge.
{%- endcomment -%}

{%- liquid
  assign cs = section.settings.color_scheme
-%}

<div
  class="avelo-tst color-{{ cs }} section"
  style="
    padding-block-start: {{ section.settings.padding_block_start }}px;
    padding-block-end: {{ section.settings.padding_block_end }}px;
  "
>
  <div class="avelo-tst__inner page-width">
    <div class="avelo-tst__head">
      {%- if section.settings.rating_text != blank -%}
        <div class="avelo-tst__rating">
          <span class="avelo-tst__stars" aria-hidden="true">★★★★★</span>
          <span class="avelo-tst__rating-text">{{ section.settings.rating_text }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="avelo-tst__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="avelo-tst__grid">
      {%- for block in section.blocks -%}
        <article class="avelo-tst__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="avelo-tst__media">
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'avelo-tst__img', alt: block.settings.name }}
            </div>
          {%- endif -%}
          <div class="avelo-tst__body">
            <span class="avelo-tst__card-stars" aria-hidden="true">★★★★★</span>
            <p class="avelo-tst__quote">{{ block.settings.quote }}</p>
            <div class="avelo-tst__author">
              <span class="avelo-tst__name">{{ block.settings.name }}</span>
              {%- if block.settings.verified -%}
                <span class="avelo-tst__verified">
                  <svg viewBox="0 0 16 16" fill="none"><path d="M8 1l1.6 1.2 2-.2.6 1.9 1.8.9-.6 1.9 1 1.7-1.4 1.4.2 2-1.9.6-.9 1.8-1.9-.6-1.7 1-1.4-1.4-2 .2-.6-1.9L1.4 11l.6-1.9-1-1.7L2.4 6l-.2-2 1.9-.6.9-1.8L6.9 2 8 1z" fill="var(--avelo-gold, #b08d57)"/><path d="M5.5 8l1.7 1.7L11 6" stroke="#fff" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified
                </span>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- stylesheet -%}
  .avelo-tst__inner { display: flex; flex-direction: column; align-items: center; }
  .avelo-tst__head { text-align: center; margin-bottom: 3rem; }
  .avelo-tst__rating { display: inline-flex; align-items: center; gap: 0.6rem; margin-bottom: 1rem; }
  .avelo-tst__stars { color: var(--avelo-gold, #b08d57); letter-spacing: 0.1em; font-size: 1rem; }
  .avelo-tst__rating-text { font-size: 0.85rem; opacity: 0.7; font-weight: 500; }
  .avelo-tst__heading {
    font-family: var(--font-h2--family);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1; letter-spacing: -0.02em; margin: 0;
    color: var(--color-foreground-heading, var(--color-foreground));
  }
  .avelo-tst__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    width: 100%;
  }
  .avelo-tst__card {
    display: flex;
    flex-direction: column;
    background: var(--color-background);
    border: 1px solid var(--color-border, rgba(0,0,0,0.08));
    border-radius: 14px;
    overflow: hidden;
  }
  .avelo-tst__media { aspect-ratio: 4 / 3; overflow: hidden; background: color-mix(in srgb, var(--color-foreground) 5%, transparent); }
  .avelo-tst__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .avelo-tst__body { padding: 1.4rem; display: flex; flex-direction: column; gap: 0.7rem; flex: 1; }
  .avelo-tst__card-stars { color: var(--avelo-gold, #b08d57); letter-spacing: 0.08em; font-size: 0.9rem; }
  .avelo-tst__quote { margin: 0; font-size: 0.95rem; line-height: 1.5; flex: 1; }
  .avelo-tst__author { display: flex; align-items: center; gap: 0.6rem; margin-top: 0.4rem; }
  .avelo-tst__name { font-weight: 600; font-size: 0.9rem; }
  .avelo-tst__verified {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.72rem; font-weight: 600; opacity: 0.75;
  }
  .avelo-tst__verified svg { width: 0.9rem; height: 0.9rem; }
  @media screen and (max-width: 989px) {
    .avelo-tst__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (max-width: 749px) {
    .avelo-tst__grid { grid-template-columns: 1fr; gap: 1.25rem; }
  }
{%- endstylesheet -%}

{% schema %}
{
  "name": "AVELO Testimonials",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "Rated 4.8 / 5 by 45,000+ customers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "45,000+ Success Stories" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-2" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_block_start", "label": "Top padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_block_end", "label": "Bottom padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 96 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Customer photo" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "I genuinely feel taller and so much more confident. No one can tell — they just look like great sneakers." },
        { "type": "text", "id": "name", "label": "Name", "default": "James R." },
        { "type": "checkbox", "id": "verified", "label": "Verified buyer", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "AVELO Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "I genuinely feel taller and so much more confident. They just look like great sneakers — no one can tell.", "name": "James R.", "verified": true } },
        { "type": "testimonial", "settings": { "quote": "Bought these for my wedding and got compliments all night. The comfort honestly shocked me.", "name": "Daniel K.", "verified": true } },
        { "type": "testimonial", "settings": { "quote": "I'm 5'7\" and always wanted a little boost for work meetings. These are perfect and so easy to wear.", "name": "Marcus T.", "verified": true } },
        { "type": "testimonial", "settings": { "quote": "Was skeptical about the height claim but it's real and totally invisible. Already ordered my second pair.", "name": "Aisha N.", "verified": true } }
      ]
    }
  ]
}
{% endschema %}
