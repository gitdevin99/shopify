{%- comment -%}
  AVELO — Lifestyle Grid ("Own Every Setting")
  Row of large lifestyle images, each labelled (Everyday / Athletic / Formal),
  optionally linking to a collection. Hover-zoom, gold label.
{%- endcomment -%}

{%- liquid
  assign cs = section.settings.color_scheme
-%}

<div
  class="avelo-life color-{{ cs }} section"
  style="
    --avelo-life-cols: {{ section.blocks.size }};
    padding-block-start: {{ section.settings.padding_block_start }}px;
    padding-block-end: {{ section.settings.padding_block_end }}px;
  "
>
  <div class="avelo-life__inner page-width">
    {%- if section.settings.heading != blank or section.settings.kicker != blank -%}
      <div class="avelo-life__head">
        {%- if section.settings.kicker != blank -%}
          <p class="avelo-life__kicker">{{ section.settings.kicker }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="avelo-life__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="avelo-life__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign has_link = false
          if block.settings.link != blank
            assign has_link = true
          endif
        -%}
        <{% if has_link %}a href="{{ block.settings.link }}"{% else %}div{% endif %} class="avelo-life__card" {{ block.shopify_attributes }}>
          <div class="avelo-life__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'avelo-life__img', alt: block.settings.label }}
            {%- else -%}
              <div class="avelo-life__placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'avelo-life__placeholder-svg' }}</div>
            {%- endif -%}
            <span class="avelo-life__overlay" aria-hidden="true"></span>
          </div>
          <div class="avelo-life__caption">
            <span class="avelo-life__label">{{ block.settings.label }}</span>
            {%- if block.settings.sublabel != blank -%}
              <span class="avelo-life__sublabel">{{ block.settings.sublabel }}</span>
            {%- endif -%}
          </div>
        </{% if has_link %}a{% else %}div{% endif %}>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- stylesheet -%}
  .avelo-life__head { text-align: center; max-width: 46rem; margin: 0 auto 3rem; }
  .avelo-life__kicker {
    font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--avelo-gold, #b08d57); font-weight: 600; margin: 0 0 0.9rem;
  }
  .avelo-life__heading {
    font-family: var(--font-h2--family);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1; letter-spacing: -0.02em; margin: 0;
    color: var(--color-foreground-heading, var(--color-foreground));
  }
  .avelo-life__grid {
    display: grid;
    grid-template-columns: repeat(var(--avelo-life-cols, 3), 1fr);
    gap: 1.25rem;
  }
  .avelo-life__card {
    position: relative;
    display: block;
    text-decoration: none;
    color: #fff;
    border-radius: 14px;
    overflow: hidden;
  }
  .avelo-life__media { position: relative; aspect-ratio: 3 / 4; overflow: hidden; background: #111; }
  .avelo-life__img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.7s cubic-bezier(0.2,0.8,0.2,1);
  }
  .avelo-life__card:hover .avelo-life__img { transform: scale(1.05); }
  .avelo-life__placeholder { width: 100%; height: 100%; }
  .avelo-life__placeholder-svg { width: 100%; height: 100%; }
  .avelo-life__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.05) 45%, transparent 70%);
  }
  .avelo-life__caption {
    position: absolute;
    left: 1.5rem; bottom: 1.5rem; right: 1.5rem;
    display: flex; flex-direction: column; gap: 0.2rem;
  }
  .avelo-life__label {
    font-family: var(--font-h3--family);
    font-size: 1.3rem; font-weight: 600; letter-spacing: -0.01em;
  }
  .avelo-life__sublabel { font-size: 0.85rem; opacity: 0.85; }
  @media screen and (max-width: 749px) {
    .avelo-life__grid { grid-template-columns: 1fr; gap: 1rem; }
    .avelo-life__media { aspect-ratio: 4 / 3; }
  }
{%- endstylesheet -%}

{% schema %}
{
  "name": "AVELO Lifestyle Grid",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Built for life" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Own every setting." },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_block_start", "label": "Top padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_block_end", "label": "Bottom padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 96 }
  ],
  "blocks": [
    {
      "type": "scene",
      "name": "Scene",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Everyday" },
        { "type": "text", "id": "sublabel", "label": "Sublabel", "default": "Effortless from coffee to closing time" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AVELO Lifestyle Grid",
      "blocks": [
        { "type": "scene", "settings": { "label": "Everyday", "sublabel": "Effortless from coffee to closing time" } },
        { "type": "scene", "settings": { "label": "Athletic", "sublabel": "Lightweight lift that keeps up" } },
        { "type": "scene", "settings": { "label": "Formal", "sublabel": "Boardroom presence, redefined" } }
      ]
    }
  ]
}
{% endschema %}
