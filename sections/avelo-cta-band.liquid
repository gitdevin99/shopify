  <div class="avelo-cta__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="avelo-cta__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="avelo-cta__body">{{ section.settings.body }}</p>
    {%- endif -%}
    <div class="avelo-cta__buttons">
      {%- if section.settings.button1_label != blank -%}
        <a href="{{ section.settings.button1_link }}" class="avelo-cta__btn">{{ section.settings.button1_label }}</a>
      {%- endif -%}
      {%- if section.settings.button2_label != blank -%}
        <a href="{{ section.settings.button2_link }}" class="avelo-cta__btn">{{ section.settings.button2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

{%- stylesheet -%}
  .avelo-cta.avelo-cta {
    position: relative;
    background-color: #000000;
    color: #ffffff;
    padding-block-start: clamp(7rem, 14vw, 11rem);
    padding-block-end: clamp(4rem, 8vw, 6rem);
    overflow: hidden;
    width: 100%;
    display: block;
  }
  .avelo-cta__wave {
    position: absolute;
    top: 0; left: 0; right: 0;
    width: 100%;
    height: clamp(60px, 9vw, 120px);
    line-height: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .avelo-cta__wave-svg {
    position: absolute;
    top: 0; left: 0;
    width: 200%;            /* two wave periods so a -50% slide is seamless */
    min-width: 200%;
    height: 100%;
    display: block;
    will-change: transform;
  }
  /* keep the band black behind the wave so any sub-pixel gap reads as black */
  .avelo-cta__wave::after {
    content: "";
    position: absolute; inset: 0;
    background: transparent;
  }
  .avelo-cta__wave-svg--back  path { fill: #2a2a2a; }
  .avelo-cta__wave-svg--front path { fill: #000000; }
  /* the area ABOVE the curve must read as the previous (light) section */
  .avelo-cta::before {
    content: "";
    position: absolute; top: -1px; left: 0; right: 0;
    height: clamp(60px, 9vw, 120px);
    background: #ffffff;
    z-index: 0;
  }
  .avelo-cta__wave { z-index: 1; }
  .avelo-cta__inner {
    position: relative; z-index: 2;
    text-align: center;
    max-width: 52rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-inline: 1.5rem;
  }

  /* continuous flowing wave — each layer slides one full period and loops seamlessly */
  .avelo-cta__wave-svg--back  { animation: avelo-wave-flow 9s linear infinite; }
  .avelo-cta__wave-svg--front { animation: avelo-wave-flow 6s linear infinite; }
  @keyframes avelo-wave-flow {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .avelo-cta__wave-svg { animation: none !important; }
  }

  .avelo-cta__heading {
    font-family: var(--font-h2--family);
    font-size: clamp(1.7rem, 4vw, 2.8rem);
    line-height: 1.12; letter-spacing: -0.02em; margin: 0;
    color: inherit;
  }
  .avelo-cta__body { margin: 1.1rem auto 0; max-width: 42rem; opacity: 0.8; line-height: 1.6; font-size: 1.05rem; }
  .avelo-cta__buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 2.25rem; }
  .avelo-cta__btn {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 12rem; padding: 1rem 2rem;
    border: 1.5px solid currentColor;
    color: inherit; text-decoration: none;
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    border-radius: 4px;
    transition: background 0.25s ease, color 0.25s ease, transform 0.2s ease;
  }
  .avelo-cta__btn:hover {
    background: var(--color-foreground, #fff);
    color: var(--color-background, #000);
    transform: translateY(-2px);
  }
  @media screen and (max-width: 480px) {
    .avelo-cta__btn { min-width: 0; width: 100%; }
  }
{%- endstylesheet -%}

{% schema %}
{
  "name": "AVELO CTA Band",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Worn by people who refuse to blend in." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Why blend in when you were born to stand out? Join 45,000+ who elevated more than just their height. With AVELO, you're not just taller — you're unstoppable." },
    { "type": "text", "id": "button1_label", "label": "Button 1 label", "default": "Shop men's" },
    { "type": "url", "id": "button1_link", "label": "Button 1 link" },
    { "type": "text", "id": "button2_label", "label": "Button 2 label", "default": "Shop women's" },
    { "type": "url", "id": "button2_link", "label": "Button 2 link" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-5" }
  ],
  "presets": [
    { "name": "AVELO CTA Band" }
  ]
}
{% endschema %}
