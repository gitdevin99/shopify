{%- comment -%}
  AVELO — Comparison Table (AVELO vs ordinary brands)
  Rows of benefits with check (AVELO) vs cross (others).
{%- endcomment -%}

{%- liquid
  assign cs = section.settings.color_scheme
-%}

<div
  class="avelo-compare color-{{ cs }} section"
  style="
    padding-block-start: {{ section.settings.padding_block_start }}px;
    padding-block-end: {{ section.settings.padding_block_end }}px;
  "
>
  <div class="avelo-compare__inner page-width">
    <div class="avelo-compare__head">
      {%- if section.settings.kicker != blank -%}
        <p class="avelo-compare__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="avelo-compare__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="avelo-compare__table">
      <div class="avelo-compare__row avelo-compare__row--header">
        <div class="avelo-compare__cell avelo-compare__cell--feature"></div>
        <div class="avelo-compare__cell avelo-compare__cell--brand avelo-compare__cell--us">
          <span class="avelo-compare__brand-name">{{ section.settings.brand_name }}</span>
        </div>
        <div class="avelo-compare__cell avelo-compare__cell--brand">
          <span class="avelo-compare__brand-name avelo-compare__brand-name--muted">{{ section.settings.other_name }}</span>
        </div>
      </div>

      {%- for block in section.blocks -%}
        <div class="avelo-compare__row" {{ block.shopify_attributes }}>
          <div class="avelo-compare__cell avelo-compare__cell--feature">
            {{ block.settings.feature }}
          </div>
          <div class="avelo-compare__cell avelo-compare__cell--us">
            <span class="avelo-compare__mark avelo-compare__mark--yes" aria-label="Yes">
              <svg viewBox="0 0 20 20" fill="none"><path d="M4 10.5L8 14.5L16 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="avelo-compare__cell">
            {%- if block.settings.other_has -%}
              <span class="avelo-compare__mark avelo-compare__mark--partial" aria-label="Partial">
                <svg viewBox="0 0 20 20" fill="none"><path d="M5 10H15" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
              </span>
            {%- else -%}
              <span class="avelo-compare__mark avelo-compare__mark--no" aria-label="No">
                <svg viewBox="0 0 20 20" fill="none"><path d="M6 6L14 14M14 6L6 14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
              </span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="avelo-compare__cta">
        <a href="{{ section.settings.button_link }}" class="button avelo-compare__button">{{ section.settings.button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{%- stylesheet -%}
  .avelo-compare__inner { display: flex; flex-direction: column; align-items: center; }
  .avelo-compare__head { text-align: center; max-width: 46rem; margin-bottom: 3rem; }
  .avelo-compare__kicker {
    font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--avelo-gold, #b08d57); font-weight: 600; margin: 0 0 0.9rem;
  }
  .avelo-compare__heading {
    font-family: var(--font-h2--family);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1; letter-spacing: -0.02em; margin: 0;
    color: var(--color-foreground-heading, var(--color-foreground));
  }
  .avelo-compare__table {
    width: 100%;
    max-width: 44rem;
    border: 1px solid var(--color-border, rgba(0,0,0,0.1));
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-background);
  }
  .avelo-compare__row {
    display: grid;
    grid-template-columns: 1fr 7rem 7rem;
    align-items: center;
    border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.08));
  }
  .avelo-compare__row:last-child { border-bottom: none; }
  .avelo-compare__row--header {
    background: color-mix(in srgb, var(--color-foreground) 4%, transparent);
  }
  .avelo-compare__cell {
    padding: 1.1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.98rem;
  }
  .avelo-compare__cell--feature {
    justify-content: flex-start;
    font-weight: 500;
    line-height: 1.35;
  }
  .avelo-compare__cell--us {
    background: color-mix(in srgb, var(--avelo-gold, #b08d57) 8%, transparent);
  }
  .avelo-compare__brand-name {
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }
  .avelo-compare__brand-name--muted { opacity: 0.55; font-weight: 600; }
  .avelo-compare__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.7rem; height: 1.7rem;
    border-radius: 50%;
  }
  .avelo-compare__mark svg { width: 1rem; height: 1rem; }
  .avelo-compare__mark--yes { background: var(--avelo-gold, #b08d57); color: #fff; }
  .avelo-compare__mark--no { background: color-mix(in srgb, var(--color-foreground) 8%, transparent); color: var(--color-foreground); opacity: 0.5; }
  .avelo-compare__mark--partial { background: color-mix(in srgb, var(--color-foreground) 8%, transparent); color: var(--color-foreground); opacity: 0.6; }
  .avelo-compare__cta { margin-top: 2.5rem; }
  .avelo-compare__button { text-decoration: none; }
  @media screen and (max-width: 749px) {
    .avelo-compare__row { grid-template-columns: 1fr 4.5rem 4.5rem; }
    .avelo-compare__cell { padding: 0.9rem 0.8rem; font-size: 0.9rem; }
    .avelo-compare__cell--feature { padding-left: 1rem; }
    .avelo-compare__brand-name { font-size: 0.8rem; }
  }
{%- endstylesheet -%}

{% schema %}
{
  "name": "AVELO Comparison",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "The difference" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why people choose AVELO" },
    { "type": "text", "id": "brand_name", "label": "Your brand name", "default": "AVELO" },
    { "type": "text", "id": "other_name", "label": "Comparison label", "default": "Others" },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the collection" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_block_start", "label": "Top padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_block_end", "label": "Bottom padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 96 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        { "type": "text", "id": "feature", "label": "Feature", "default": "Up to 12cm invisible height" },
        { "type": "checkbox", "id": "other_has", "label": "Others have this (partial)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "AVELO Comparison",
      "blocks": [
        { "type": "row", "settings": { "feature": "Up to 12cm of invisible height", "other_has": false } },
        { "type": "row", "settings": { "feature": "Engineered ergonomic midsole", "other_has": false } },
        { "type": "row", "settings": { "feature": "Premium full-grain materials", "other_has": true } },
        { "type": "row", "settings": { "feature": "All-day, no-pain comfort", "other_has": false } },
        { "type": "row", "settings": { "feature": "Looks like a normal sneaker", "other_has": true } },
        { "type": "row", "settings": { "feature": "30-day money-back guarantee", "other_has": false } }
      ]
    }
  ]
}
{% endschema %}
