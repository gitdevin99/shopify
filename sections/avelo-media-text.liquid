{%- comment -%}
  AVELO — Media + Text ("First Impression Counts")
  Image on one side, heading/body/optional button on the other. Reversible.
{%- endcomment -%}

{%- liquid
  assign cs = section.settings.color_scheme
  assign reverse = section.settings.image_position
-%}

<div
  class="avelo-mt color-{{ cs }} section"
  style="
    padding-block-start: {{ section.settings.padding_block_start }}px;
    padding-block-end: {{ section.settings.padding_block_end }}px;
  "
>
  <div class="avelo-mt__inner page-width avelo-mt--{{ reverse }}">
    <div class="avelo-mt__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1100 | image_tag: loading: 'lazy', class: 'avelo-mt__img', alt: section.settings.heading }}
      {%- else -%}
        <div class="avelo-mt__placeholder">{{ 'image' | placeholder_svg_tag: 'avelo-mt__placeholder-svg' }}</div>
      {%- endif -%}
    </div>
    <div class="avelo-mt__content">
      {%- if section.settings.kicker != blank -%}
        <p class="avelo-mt__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="avelo-mt__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="avelo-mt__body rte">{{ section.settings.body }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button avelo-mt__button">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

{%- stylesheet -%}
  .avelo-mt__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 5vw, 4.5rem);
    align-items: center;
  }
  .avelo-mt--right .avelo-mt__media { order: 2; }
  .avelo-mt__media { border-radius: 16px; overflow: hidden; aspect-ratio: 5 / 4; background: #111; }
  .avelo-mt__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .avelo-mt__placeholder { width: 100%; height: 100%; }
  .avelo-mt__placeholder-svg { width: 100%; height: 100%; opacity: 0.2; }
  .avelo-mt__kicker {
    font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--avelo-gold, #b08d57); font-weight: 600; margin: 0 0 0.9rem;
  }
  .avelo-mt__heading {
    font-family: var(--font-h2--family);
    font-size: clamp(1.7rem, 3.6vw, 2.6rem);
    line-height: 1.1; letter-spacing: -0.02em; margin: 0;
    color: var(--color-foreground-heading, var(--color-foreground));
  }
  .avelo-mt__body { margin-top: 1.1rem; opacity: 0.74; line-height: 1.6; font-size: 1.05rem; }
  .avelo-mt__body > *:first-child { margin-top: 0; }
  .avelo-mt__button { margin-top: 1.75rem; text-decoration: none; display: inline-flex; }
  @media screen and (max-width: 749px) {
    .avelo-mt__inner { grid-template-columns: 1fr; gap: 1.75rem; }
    .avelo-mt--right .avelo-mt__media { order: 0; }
    .avelo-mt__media { aspect-ratio: 16 / 11; }
  }
{%- endstylesheet -%}

{% schema %}
{
  "name": "AVELO Media + Text",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select", "id": "image_position", "label": "Image position",
      "options": [ { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ],
      "default": "left"
    },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Confidence" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "First impressions count." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Height shapes how a room reads you — before you say a word. AVELO gives you that quiet edge of presence and posture, so you walk in already standing taller.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the collection" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_block_start", "label": "Top padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_block_end", "label": "Bottom padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [
    { "name": "AVELO Media + Text" }
  ]
}
{% endschema %}
