{%- comment -%}
  AVELO — UGC / Reactions Video
  Phone-framed video (uploaded or external) beside reaction stats + heading.
{%- endcomment -%}

{%- liquid
  assign cs = section.settings.color_scheme
-%}

<div
  class="avelo-ugc color-{{ cs }} section"
  style="
    padding-block-start: {{ section.settings.padding_block_start }}px;
    padding-block-end: {{ section.settings.padding_block_end }}px;
  "
>
  <div class="avelo-ugc__inner page-width">
    <div class="avelo-ugc__text">
      {%- if section.settings.kicker != blank -%}
        <p class="avelo-ugc__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="avelo-ugc__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="avelo-ugc__body rte">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="avelo-ugc__stats">
          {%- for block in section.blocks -%}
            <div class="avelo-ugc__stat" {{ block.shopify_attributes }}>
              <span class="avelo-ugc__stat-value">{{ block.settings.value }}</span>
              <span class="avelo-ugc__stat-label">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button avelo-ugc__button">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>

    <div class="avelo-ugc__media-wrap">
      <div class="avelo-ugc__phone">
        <div class="avelo-ugc__screen">
          {%- if section.settings.video != blank -%}
            {{ section.settings.video | video_tag: loop: true, controls: true, muted: false, image_size: '600x', class: 'avelo-ugc__video' }}
          {%- elsif section.settings.video_url != blank -%}
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe
                class="avelo-ugc__iframe"
                src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?rel=0"
                title="{{ section.settings.heading | escape }}"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {%- elsif section.settings.video_url.type == 'vimeo' -%}
              <iframe
                class="avelo-ugc__iframe"
                src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}"
                title="{{ section.settings.heading | escape }}"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {%- endif -%}
          {%- elsif section.settings.poster != blank -%}
            {{ section.settings.poster | image_url: width: 600 | image_tag: loading: 'lazy', class: 'avelo-ugc__video', alt: '' }}
          {%- else -%}
            <div class="avelo-ugc__placeholder">{{ 'image' | placeholder_svg_tag: 'avelo-ugc__placeholder-svg' }}</div>
          {%- endif -%}
        </div>
        <span class="avelo-ugc__notch" aria-hidden="true"></span>
      </div>
    </div>
  </div>
</div>

{%- stylesheet -%}
  .avelo-ugc__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .avelo-ugc__kicker {
    font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--avelo-gold, #b08d57); font-weight: 600; margin: 0 0 0.9rem;
  }
  .avelo-ugc__heading {
    font-family: var(--font-h2--family);
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.08; letter-spacing: -0.02em; margin: 0;
    color: var(--color-foreground-heading, var(--color-foreground));
  }
  .avelo-ugc__body { margin-top: 1.1rem; font-size: 1.05rem; line-height: 1.55; opacity: 0.72; }
  .avelo-ugc__stats { display: flex; gap: 2.5rem; margin-top: 2rem; flex-wrap: wrap; }
  .avelo-ugc__stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .avelo-ugc__stat-value {
    font-family: var(--font-h1--family);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 600; line-height: 1; letter-spacing: -0.02em;
    color: var(--avelo-gold, #b08d57);
  }
  .avelo-ugc__stat-label { font-size: 0.85rem; line-height: 1.35; opacity: 0.7; max-width: 12rem; }
  .avelo-ugc__button { margin-top: 2rem; text-decoration: none; align-self: flex-start; }
  .avelo-ugc__media-wrap { display: flex; justify-content: center; }
  .avelo-ugc__phone {
    position: relative;
    width: min(300px, 78%);
    aspect-ratio: 9 / 19;
    background: #0a0a0a;
    border-radius: 2.6rem;
    padding: 0.7rem;
    box-shadow: 0 30px 60px -20px rgba(0,0,0,0.45), 0 0 0 2px rgba(255,255,255,0.04) inset;
  }
  .avelo-ugc__screen {
    position: relative;
    width: 100%; height: 100%;
    border-radius: 2rem;
    overflow: hidden;
    background: #000;
  }
  .avelo-ugc__video, .avelo-ugc__iframe, .avelo-ugc__placeholder {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; border: 0;
  }
  .avelo-ugc__placeholder-svg { width: 100%; height: 100%; opacity: 0.2; }
  .avelo-ugc__notch {
    position: absolute;
    top: 1rem; left: 50%; transform: translateX(-50%);
    width: 38%; height: 1.5rem;
    background: #0a0a0a;
    border-radius: 100px;
    z-index: 2;
  }
  @media screen and (max-width: 749px) {
    .avelo-ugc__inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .avelo-ugc__media-wrap { order: -1; }
    .avelo-ugc__phone { width: min(260px, 70%); }
  }
{%- endstylesheet -%}

{% schema %}
{
  "name": "AVELO UGC Video",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Real reactions" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "People's reactions: NYC edition" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>We hit the streets of New York and handed out shoes to random people on the spot. Here's what they said.</p>" },
    { "type": "header", "content": "Video" },
    { "type": "video", "id": "video", "label": "Uploaded video" },
    { "type": "video_url", "id": "video_url", "label": "Or video URL (YouTube / Vimeo)", "accept": ["youtube", "vimeo"] },
    { "type": "image_picker", "id": "poster", "label": "Poster image (fallback)" },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_block_start", "label": "Top padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_block_end", "label": "Bottom padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 96 }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Reaction stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "45,000+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Increased their height" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AVELO UGC Video",
      "blocks": [
        { "type": "stat", "settings": { "value": "45,000+", "label": "Increased their height" } },
        { "type": "stat", "settings": { "value": "65%", "label": "Ordered a second pair" } },
        { "type": "stat", "settings": { "value": "93%", "label": "Felt more confident" } }
      ]
    }
  ]
}
{% endschema %}
