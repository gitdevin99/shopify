    "avelo_faq": {
      "type": "avelo-faq",
      "blocks": {
        "q1": {
          "type": "faq",
          "settings": {
            "question": "Will anyone be able to tell I'm wearing elevator shoes?",
            "answer": "<p>No. The elevation is built entirely inside the shoe with a precision-engineered midsole. From the outside, AVELO looks exactly like a premium designer shoe.</p>"
          }
        },
        "q2": {
          "type": "faq",
          "settings": {
            "question": "Are they comfortable enough for all-day wear?",
            "answer": "<p>Yes. Every pair uses an ergonomic, weight-distributing midsole with memory-foam cushioning, designed to be worn from morning to night.</p>"
          }
        },
        "q3": {
          "type": "faq",
          "settings": {
            "question": "How do I choose my size?",
            "answer": "<p>Order your normal shoe size — AVELO fits true to size. If you're between sizes, we recommend sizing up.</p>"
          }
        },
        "q4": {
          "type": "faq",
          "settings": {
            "question": "What's your return policy?",
            "answer": "<p>We offer a 30-day money-back guarantee. If you're not completely happy, send them back for a full refund.</p>"
          }
        },
        "q5": {
          "type": "faq",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Orders ship within 1–2 business days and typically arrive in 5–9 business days. Free shipping on orders over $80.</p>"
          }
        }
      },
